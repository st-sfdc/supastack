###############################################################

# SCHEMA F — Environment Variables

# Kopiere diese Datei: cp env.example .env

# Dann alle Werte anpassen!

###############################################################

# —————————————————––

# ALLGEMEIN

# —————————————————––

ENVIRONMENT=development
SITE_URL=http://localhost:3000

# —————————————————––

# SUPABASE — Werte aus supabase/docker/.env übernehmen
#
# Keys generieren (falls noch nicht geschehen):
#   cd supabase/docker && sh ./utils/generate-keys.sh
#
# Keys anzeigen:
#   grep -E "^ANON_KEY|^SERVICE_ROLE_KEY|^JWT_SECRET" supabase/docker/.env
#
# Studio (Admin UI) → http://localhost:8000
# Login: DASHBOARD_USERNAME / DASHBOARD_PASSWORD aus supabase/docker/.env

# —————————————————––

SUPABASE_URL=http://localhost:8000
ANON_KEY=WERT_AUS_SUPABASE_DOCKER_ENV
SERVICE_ROLE_KEY=WERT_AUS_SUPABASE_DOCKER_ENV
JWT_SECRET=WERT_AUS_SUPABASE_DOCKER_ENV

# —————————————————––

# DATENBANK — direkte Verbindung für FastAPI
# Passwort: POSTGRES_PASSWORD aus supabase/docker/.env

# —————————————————––

# When running backend in Docker (connects directly to supabase-db container):
DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@supabase-db:5432/postgres
# When running backend locally (outside Docker), use localhost:
# DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@localhost:5432/postgres

# —————————————————––

# FRONTEND (Vite)

# —————————————————––

# Local: goes through nginx on port 2026
VITE_API_URL=http://localhost:2026/api
# Remote (Cloudflare Tunnel): set this to your tunnel domain
# VITE_API_URL=https://your-tunnel-domain.com/api
# VITE_SUPABASE_URL is intentionally omitted — the app derives it automatically
# from window.location.origin + '/supabase', routed through Nginx.
# This means it works from localhost, local network, or Cloudflare without changes.
VITE_SUPABASE_ANON_KEY=WERT_AUS_SUPABASE_DOCKER_ENV
