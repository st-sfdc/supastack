# SupaStack — Environment Variables
#
# Copy this file: cp .env.example .env
# Then fill in all values.

# ── General ──────────────────────────────────────────────────────────────────

ENVIRONMENT=development
SITE_URL=http://localhost:2026

# ── Supabase — copy values from supabase/docker/.env ─────────────────────────
#
# Generate keys (if not done yet):
#   cd supabase/docker && sh ./utils/generate-keys.sh
#
# Display values to copy:
#   grep -E "^ANON_KEY|^SERVICE_ROLE_KEY|^JWT_SECRET|^POSTGRES_PASSWORD" supabase/docker/.env
#
# Studio (Admin UI) → http://localhost:8000
# Login: DASHBOARD_USERNAME / DASHBOARD_PASSWORD from supabase/docker/.env

SUPABASE_URL=http://localhost:8000
ANON_KEY=your_anon_key_here
SERVICE_ROLE_KEY=your_service_role_key_here
JWT_SECRET=your_jwt_secret_here

# Internal URL used by the backend container to reach Supabase (Kong) directly.
# Do not change this unless your Supabase container name differs.
SUPABASE_INTERNAL_URL=http://supabase-kong:8000

# ── Database — direct connection for FastAPI ──────────────────────────────────
# Password: POSTGRES_PASSWORD from supabase/docker/.env

# When running backend in Docker (connects directly to supabase-db container):
DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@supabase-db:5432/postgres
# When running backend locally (outside Docker), use localhost:
# DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@localhost:5432/postgres

# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# Local: goes through Nginx on port 2026
VITE_API_URL=http://localhost:2026/api
# Remote (Cloudflare Tunnel or custom domain): set to your domain
# VITE_API_URL=https://your-domain.com/api

# VITE_SUPABASE_URL is intentionally omitted — the app derives it automatically
# from window.location.origin + '/supabase', routed through Nginx.
# This means it works from localhost, local network, or a tunnel without changes.
VITE_SUPABASE_ANON_KEY=your_anon_key_here
